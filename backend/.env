# ═══════════════════════════════════════════════
# CSC SEVA KENDRA — Environment Variables
# COPY THIS FILE TO .env AND FILL IN VALUES
# NEVER COMMIT .env TO GIT!
# ═══════════════════════════════════════════════

# Server
NODE_ENV=development
PORT=3001

# JWT — generate a long random secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=b555cd7ca290aeb2ed9d42b32b04653aa9036eb179d3300c160c76d2802fafd28f57f828731f494bba1f9163aa7fa2726bdc3086cfad9801953cc010d7b89b6a
JWT_EXPIRES_IN=6h

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://yourdomain.in

# Database (SQLite path)
DB_PATH=./db/csc.db

# Upload directory
UPLOADS_DIR=./uploads
MAX_FILE_SIZE_MB=2

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Admin — initial credentials (used only by create-admin.js)
# REMOVE THESE FROM .env AFTER FIRST RUN
INITIAL_ADMIN_USER=admin
INITIAL_ADMIN_PASS=IamSamarth@1234

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
