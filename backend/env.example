# ═══════════════════════════════════════════════
# CSC SEVA KENDRA — Environment Variables
# COPY THIS FILE TO .env AND FILL IN VALUES
# NEVER COMMIT .env TO GIT!
# ═══════════════════════════════════════════════

# Server
NODE_ENV=development
PORT=3000

# JWT — generate a long random secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_MIN_64_CHARS
JWT_EXPIRES_IN=8h

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://yourdomain.in

# Database (SQLite path)
DB_PATH=./db/csc.db

# Upload directory
UPLOADS_DIR=./uploads
MAX_FILE_SIZE_MB=2

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AUTH_RATE_LIMIT_MAX=10

# Admin — initial credentials (used only by create-admin.js)
# REMOVE THESE FROM .env AFTER FIRST RUN
INITIAL_ADMIN_USER=admin
INITIAL_ADMIN_PASS=ChangeMe@2025!

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
